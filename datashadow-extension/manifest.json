{
  "manifest_version": 3,
  "name": "DataShadow",
  "version": "1.0",
  "description": "Expose the shadow data websites collect about you.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["fingerprinter-shield.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["report.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
