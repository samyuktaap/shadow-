{
  "manifest_version": 3,
  "name": "DataShadow",
  "version": "1.1",
  "description": "Expose the shadow data websites collect about you.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "identity",
    "geolocation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": []
  },
  "background": {
    "service_worker": "src/scripts/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com data:; connect-src 'self' https://*.tile.openstreetmap.org https://*.basemaps.cartocdn.com https://*.supabase.co;"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/fingerprinter-shield.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/content.js"]
    }
  ],
  "action": {
    "default_popup": "src/pages/popup.html"
  },
  "icons": {
    "128": "public/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/pages/*.html", "public/*", "src/pages/*.css", "src/pages/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
