{
  "manifest_version": 3,
  "name": "DataShadow",
  "version": "1.0",
  "description": "Expose the shadow data websites collect about you.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "identity"
  ],
  "oauth2": {
    "client_id": "605149597240-evauu46jjo7s802tbnaphnpvenoklqml.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/scripts/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/fingerprinter-shield.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/content.js"]
    }
  ],
  "action": {
    "default_popup": "src/pages/popup.html"
  },
  "icons": {
    "128": "public/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/pages/report.html", "src/pages/dashboard.html", "src/pages/pro.html", "public/world-map.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
